<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{title}}</title>
  <style>
    {{{css}}}
    {{#if features.pageNumbers}}
    @page {
      @bottom-center {
        content: "Page " counter(page) " of " counter(pages);
      }
    }
    {{else}}
    @page {
      @bottom-center {
        content: "";
      }
    }
    {{/if}}
  </style>
  <style media="screen">
    @media screen {
      .pagedjs_page {
        box-shadow: 0 0 0 1px rgba(0, 0,0,0.2);
      }
    }
  </style>
  <script src="https://unpkg.com/pagedjs@0.4.3/dist/paged.js"></script>
  <script>
    let previewer = new Paged.Previewer();
    window.addEventListener('DOMContentLoaded', async () => {
      await previewer.preview()
      {{!-- window.print() --}}
    });
  </script>
</head>
<body>
  <div id="metadata">
    <div id="top-left">
      <div class="document-title">{{title}}</div>
      {{#if properties.author}}
      <div class="document-meta">Author: {{properties.author.name}} ({{properties.author.role}})</div>
      {{/if}}
      {{#if properties.submitted_by}}
      <div class="document-meta">Submitted by: {{properties.submitted_by.name}} ({{properties.submitted_by.role}})</div>
      {{/if}}
    </div>
    <div id="top-right">
      {{#if properties.case_number}}
      <div class="document-meta">Case Number: {{properties.case_number}}</div>
      {{/if}}
      {{#if properties.date}}
      <div class="document-meta">Date: {{formatDate properties.date}}</div>
      {{/if}}
    </div>
    <div id="bottom-left">
      <span></span>
      {{#if features.docID}}
      <div>Document ID:</div>
      <div class="document-id">{{hashId id}}</div>
      {{/if}}
    </div>
    <div id="bottom-right">
      {{#if features.initialsField}}
      <div class="initials-field">
        <div class="initials-section">
          <div class="initials-row">
            <div class="initials-column">
              <div class="initials-line">Applicant</div>
            </div>
            <div class="initials-column">
              <div class="initials-line">Respondent</div>
            </div>
          </div>
          <div class="initials-row">
            <div class="initials-column">
              <div class="initials-line">Counsel</div>
            </div>
            <div class="initials-column">
              <div class="initials-line">Counsel</div>
            </div>
          </div>
        </div>
      </div>
      {{/if}}
    </div>
  </div>

  <div class="document-content">
    {{#each content}}
      {{#if type}}
        {{#if (eq type "heading")}}
        <div class="heading">
          <div class="heading-title">{{{renderTemplate text}}}</div>
          {{#if subTitle}}
          <div class="heading-subtitle">{{{renderTemplate subTitle}}}</div>
          {{/if}}
        </div>
        {{/if}}
        {{#if (eq type "paragraph")}}
        <div class="paragraph">
          {{#if number}}<span class="paragraph-number">{{number}}.</span>{{/if}}
          {{{renderTemplate text}}}
          {{#if content}}
          <div class="subparagraph-block">
            {{#each content}}
            <div class="subparagraph">
              {{#if letter}}<span class="subparagraph-letter">{{letter}}.</span>{{/if}}
              {{{renderTemplate text}}}
            </div>
            {{/each}}
          </div>
          {{/if}}
        </div>
        {{/if}}
      {{else}}
        <div class="paragraph">{{this}}</div>
      {{/if}}
    {{/each}}

    {{#if features.signatoryPage}}
    <div class="page-break-before signatory-page">
      <div class="signatory-title">Signature Page</div>
      <div class="signatory-blocks">
        {{#if features.signatoryPage.applicant}}
        <div class="signatory-block">
          <div class="signatory-party-label">Applicant</div>
          <div class="signatory-line"><span class="signatory-line-label">Signature</span></div>
          <div class="signatory-line"><span class="signatory-line-label">Name</span></div>
          <div class="signatory-line"><span class="signatory-line-label">Date</span></div>
          {{#if features.signatoryPage.includeCounsel}}
          <div class="signatory-party-label signatory-counsel-label">Counsel for Applicant</div>
          <div class="signatory-line"><span class="signatory-line-label">Signature</span></div>
          <div class="signatory-line"><span class="signatory-line-label">Name</span></div>
          <div class="signatory-line"><span class="signatory-line-label">Date</span></div>
          {{/if}}
        </div>
        {{/if}}
        {{#if features.signatoryPage.respondent}}
        <div class="signatory-block">
          <div class="signatory-party-label">Respondent</div>
          <div class="signatory-line"><span class="signatory-line-label">Signature</span></div>
          <div class="signatory-line"><span class="signatory-line-label">Name</span></div>
          <div class="signatory-line"><span class="signatory-line-label">Date</span></div>
          {{#if features.signatoryPage.includeCounsel}}
          <div class="signatory-party-label signatory-counsel-label">Counsel for Respondent</div>
          <div class="signatory-line"><span class="signatory-line-label">Signature</span></div>
          <div class="signatory-line"><span class="signatory-line-label">Name</span></div>
          <div class="signatory-line"><span class="signatory-line-label">Date</span></div>
          {{/if}}
        </div>
        {{/if}}
      </div>
    </div>
    {{/if}}
  </div>
</body>
</html>
