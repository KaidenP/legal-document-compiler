<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Legal Document Viewer</title>
  <link rel="stylesheet" href="/viewer.css">
</head>
<body>
  <div class="sidebar" id="sidebar">
    <div class="sidebar-header">
      <h2>Documents</h2>
      <button class="sidebar-toggle" id="sidebarToggle" aria-label="Toggle sidebar">
        <span class="toggle-icon">☰</span>
      </button>
    </div>
    <ul id="docList">
      {{#if documents}}
        {{#each documents}}
          <li class="doc-item" onclick="selectDocument(this, {name: '{{this.name}}', html: '{{this.html}}', pdf: '{{this.pdf}}'})">
            <div class="doc-name">{{this.name}}</div>
          </li>
        {{/each}}
      {{else}}
        <li class="no-documents">No documents generated</li>
      {{/if}}
    </ul>
  </div>

  <div class="viewer">
    <div class="toolbar">
      <div class="toolbar-left">
        <h1 id="docTitle">Select a document</h1>
      </div>
      <div class="toolbar-right">
        <div class="format-buttons" id="formatButtons"></div>
        <div class="status" id="docStatus"></div>
      </div>
    </div>
    <div id="content">
      <iframe id="viewer"></iframe>
    </div>
  </div>

  <script src="/viewer.js"></script>
</body>
</html>
