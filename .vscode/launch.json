{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "bun",
      "internalConsoleOptions": "openOnSessionStart",
      "request": "launch",
      "name": "Generate Documents",
      "program": "src/cli/legal-doc-gen.ts",
      "args": ["doc"],
      "cwd": "${workspaceFolder}",
      "stopOnEntry": false,
      "watchMode": false
    },
    {
      "type": "bun",
      "internalConsoleOptions": "openOnSessionStart",
      "request": "launch",
      "name": "Generate Documents (watch)",
      "program": "src/cli/legal-doc-gen.ts",
      "args": ["doc", "--watch"],
      "cwd": "${workspaceFolder}",
      "stopOnEntry": false,
      "watchMode": true,
      "runtimeArgs": ["--no-clear-screen"],
    },
    {
      "type": "bun",
      "internalConsoleOptions": "openOnSessionStart",
      "request": "launch",
      "name": "Generate Examples",
      "program": "src/cli/legal-doc-gen.ts",
      "args": ["gen"],
      "cwd": "${workspaceFolder}",
      "stopOnEntry": false,
      "watchMode": false
    },
    {
      "type": "bun",
      "internalConsoleOptions": "neverOpen",
      "request": "launch",
      "name": "Debug: Watch Mode",
      "program": "src/cli/legal-doc-gen.ts",
      "args": ["watch", "-p", "5173"],
      "cwd": "${workspaceFolder}",
      "stopOnEntry": false,
      "watchMode": false
    },
    {
      "type": "bun",
      "internalConsoleOptions": "neverOpen",
      "request": "launch",
      "name": "Run Current File",
      "program": "${file}",
      "cwd": "${workspaceFolder}",
      "noDebug": true,
      "watchMode": false
    },
    {
      "type": "bun",
      "internalConsoleOptions": "neverOpen",
      "request": "attach",
      "name": "Attach Bun",
      "url": "ws://localhost:6499/",
      "stopOnEntry": false
    }
  ]
}