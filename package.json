{
  "name": "legal-doc-compiler",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "bin": "src/cli/legal-doc-gen.ts",
  "scripts": {
    "app": "bun run src/cli/legal-doc-gen.ts",
    "test": "bun test",
    "typedoc": "bunx --bun typedoc",
    "format": "prettier --write 'src/**/*.ts'",
    "format-check": "prettier --check 'src/**/*.ts'",
    "postinstall": "patch-package"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/js-yaml": "^4.0.9",
    "bun-types": "^1.3.13",
    "prettier": "^3.2.0",
    "typedoc": "^0.28.19",
    "typedoc-github-theme": "^0.4.0",
    "typedoc-plugin-markdown": "^4.11.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "handlebars": "^4.7.9",
    "js-yaml": "^4.1.1",
    "lorem-ipsum": "^2.0.8",
    "patch-package": "^8.0.1",
    "puppeteer": "^24.42.0",
    "shell": "^0.12.0",
    "typedoc-plugin-inline-sources": "^1.3.0",
    "typedoc-plugin-zod": "^1.4.3",
    "zod": "^4.3.6"
  }
}
