{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": ["src/**/*.ts"],
  "outputs": [
        {
            // requires typedoc-plugin-markdown
            "name": "markdown",
            "path": "./docs/markdown"
        },
        {
            "name": "html",
            "path": "./docs/html",
            "options": {
                "navigation": {
                    "includeCategories": true,
                    "includeGroups": true,
                    "excludeReferences": false,
                    "includeFolders": true
                }
            }
        },
        {
            "name": "json",
            "path": "./docs/docs.json"
        }
    ],
    "plugin": ["typedoc-plugin-markdown", "typedoc-plugin-zod", "typedoc-plugin-inline-sources"],
    "useTsLinkResolution": true
}